# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# PLACES_API_KEY: Optional API Key for Google Places API key calls.
# If configured in AI Studio Secrets, this key will be used to make real Google Places searches.
# If not configured, the app gracefully falls back to a high-fidelity simulated database.
PLACES_API_KEY=MY_PLACES_API_KEY

# SUPABASE_URL: The API URL endpoint of your Supabase project (e.g. https://xxxxxx.supabase.co)
SUPABASE_URL=MY_SUPABASE_URL_PLACEHOLDER

# SUPABASE_ANON_KEY: The public anon key for your Supabase project to authenticate REST requests
SUPABASE_ANON_KEY=MY_SUPABASE_ANON_KEY_PLACEHOLDER
